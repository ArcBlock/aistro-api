{
  "name": "aistro-ai",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "blocklet dev",
    "lint": "tsc --noEmit && eslint src api/src --ext .mjs,.js,.jsx,.ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "start": "cross-env NODE_ENV=development nodemon --exec tsx api/dev.ts -w api",
    "clean": "node scripts/build-clean.mjs",
    "bundle": "tsc --noEmit && npm run bundle:client && npm run bundle:api",
    "bundle:client": "vite build",
    "bundle:api": "npm run clean && tsc -p tsconfig.api.json && cp -r api/src/prompts prompts && blocklet bundle --compact --create-release --external @aigne/sqlite,sqlite3,mariadb",
    "deploy": "npm run bundle && blocklet deploy .blocklet/bundle",
    "upload": "npm run bundle && blocklet upload .blocklet/release/blocklet.json",
    "prepare": "npx simple-git-hooks",
    "bump-version": "zx --quiet scripts/bump-version.mjs"
  },
  "lint-staged": {
    "*.{mjs,js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{css,less,scss,json,graphql}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@aigne/aigne-hub": "^0.10.16",
    "@aigne/core": "^1.72.0",
    "@arcblock/did-auth-storage-nedb": "^1.7.1",
    "@arcblock/did-connect-storage-nedb": "^1.8.0",
    "@blocklet/logger": "^1.17.11",
    "@blocklet/sdk": "^1.17.7",
    "@mapbox/search-js-react": "^1.0.0-beta.22",
    "@monaco-editor/react": "^4.6.0",
    "@ocap/client": "^1.28.3",
    "@ocap/mcrypto": "^1.28.3",
    "@ocap/wallet": "^1.28.3",
    "ahooks": "^3.8.1",
    "animate.css": "^4.1.1",
    "axios": "^1.7.9",
    "circular-natal-horoscope-js": "^1.1.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "copy-to-clipboard": "^3.3.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "dotenv-flow": "^4.1.0",
    "dsbridge": "^3.1.4",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "fast-deep-equal": "^3.1.3",
    "flat": "^6.0.1",
    "google-auth-library": "^10.6.2",
    "google-play-billing-validator": "^2.1.3",
    "immer": "^10.1.1",
    "joi": "^18.0.2",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "locale-codes": "^1.3.1",
    "lodash": "^4.17.23",
    "lunarphase-calculator": "file:lunarphase-calculator",
    "mariadb": "^3.5.2",
    "mime-types": "^3.0.2",
    "monaco-editor": "^0.50.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "node-apple-receipt-verify": "^1.15.0",
    "node-cron": "^4.2.1",
    "numbro": "^2.5.0",
    "queue": "^7.0.0",
    "react-animate-number-ticker": "^1.0.2",
    "react-error-boundary": "^4.0.13",
    "react-markdown": "^9.0.1",
    "react-render-image": "^3.0.1",
    "react-scroll-to-bottom": "^4.2.0",
    "react-share": "^5.1.0",
    "react-use": "^17.5.1",
    "readable-stream-clone": "^1.0.0",
    "sequelize": "^6.37.8",
    "snowflake-uuid": "^1.0.0",
    "sqlite3": "^5.1.7",
    "ufo": "^1.6.3",
    "umzug": "^3.8.2",
    "verify-apple-id-token": "^3.1.2"
  },
  "devDependencies": {
    "@arcblock/did-connect": "^3.0.43",
    "@arcblock/eslint-config": "^0.3.3",
    "@arcblock/eslint-config-ts": "^0.3.3",
    "@arcblock/react-hooks": "^3.4.8",
    "@arcblock/ux": "^3.4.8",
    "@arcblock/ws": "^1.28.6",
    "@blocklet/js-sdk": "^1.17.7",
    "@blocklet/ui-react": "^3.4.8",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.2.0",
    "@mui/lab": "^7.0.0-beta.14",
    "@mui/material": "^7.2.0",
    "@mui/system": "^7.3.9",
    "@mui/x-data-grid": "^7.13.0",
    "@mui/x-date-pickers": "^7.13.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/dotenv-flow": "^3.3.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.19",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.6.0",
    "bumpp": "^9.11.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "import-sort-style-module": "^6.0.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.1",
    "prettier-plugin-import-sort": "^0.0.7",
    "react": "~19.1.0",
    "react-dom": "~19.1.0",
    "react-router-dom": "^6.29.0",
    "rimraf": "^5.0.10",
    "simple-git-hooks": "^2.11.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vite-plugin-blocklet": "^0.14.6",
    "vite-plugin-svgr": "^4.3.0",
    "zx": "^8.3.2"
  },
  "importSort": {
    ".js, .jsx, .mjs": {
      "parser": "babylon",
      "style": "module"
    },
    ".ts, .tsx": {
      "style": "module",
      "parser": "typescript"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "sqlite3",
      "simple-git-hooks"
    ],
    "overrides": {
      "@arcblock/did": "^1.28.6",
      "@arcblock/did-util": "^1.28.6",
      "@arcblock/jwt": "^1.28.6",
      "@arcblock/ux": "^3.4.8",
      "@arcblock/validator": "^1.28.6",
      "@arcblock/vc": "^1.28.6",
      "@arcblock/ws": "^1.28.6",
      "@blocklet/js-sdk": "^1.17.7",
      "@blocklet/logger": "^1.17.7",
      "@blocklet/sdk": "^1.17.7",
      "@ocap/client": "^1.28.6",
      "@ocap/mcrypto": "^1.28.6",
      "@ocap/util": "^1.28.6",
      "@ocap/wallet": "^1.28.6",
      "@mui/system": "^7.2.0"
    }
  }
}
